# TiDB (MySQL compatible - get from tidbcloud.com)
MYSQL_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database
MYSQL_PORT=4000

# JWT
JWT_SECRET=your_secret_key_here

# Setup endpoint secret (run /api/setup?secret=THIS_VALUE once after deploy)
SETUP_SECRET=your_setup_secret_here

# Email (Gmail App Password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Cloudinary (for image uploads - get from cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
